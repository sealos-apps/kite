{
  "name": "kite-desktop",
  "private": true,
  "version": "0.3.2-p5-a070ad4",
  "description": "Desktop wrapper for Kite",
  "main": "electron/main.cjs",
  "scripts": {
    "ensure-electron": "node ./scripts/ensure-electron.mjs",
    "generate-icons": "node ./scripts/generate-icons.mjs",
    "sync-version": "node ./scripts/sync-version.mjs",
    "prepare-backend": "node ./scripts/prepare-backend.mjs",
    "dev": "pnpm run sync-version && pnpm run ensure-electron && pnpm run prepare-backend && electron .",
    "pack": "pnpm run sync-version && pnpm run ensure-electron && pnpm run prepare-backend && electron-builder --dir",
    "dist": "pnpm run sync-version && pnpm run ensure-electron && pnpm run prepare-backend && electron-builder"
  },
  "devDependencies": {
    "electron": "^35.3.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "io.kite.desktop",
    "productName": "Kite",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "icons/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icons/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "icons/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icons/icon.ico"
    }
  },
  "packageManager": "pnpm@10.19.0"
}
